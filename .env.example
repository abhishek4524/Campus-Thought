# ==============================================================================
# Django General Settings
# ==============================================================================
DEBUG=False
SECRET_KEY=django-insecure-your-super-secret-key-replace-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com

# ==============================================================================
# PostgreSQL Database Settings
# ==============================================================================
DB_NAME=campusthoughts
DB_USER=campus_admin
DB_PASSWORD=your-secure-postgres-password
DB_HOST=127.0.0.1
DB_PORT=5432

# ==============================================================================
# SimpleJWT Security Settings
# ==============================================================================
JWT_SECRET_KEY=your-jwt-signing-secret-key-keep-safe
ACCESS_TOKEN_LIFETIME_MINUTES=60
REFRESH_TOKEN_LIFETIME_DAYS=7

# ==============================================================================
# Cloudinary Image Storage
# ==============================================================================
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
